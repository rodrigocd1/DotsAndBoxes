# ══════════════════════════════════════════════════════════════════════════════
# Dots & Boxes: Master — Variáveis de Ambiente
# ══════════════════════════════════════════════════════════════════════════════
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com credenciais reais.
# ══════════════════════════════════════════════════════════════════════════════

# ── No-IP / DDNS (Servidor Beta) ─────────────────────────────────────────────
NOIP_DDNS_HOSTNAME=dbm-beta.myftp.biz
NOIP_DDNS_USERNAME=<preencher_localmente>
NOIP_DDNS_PASSWORD=<preencher_localmente>
NOIP_UPDATE_INTERVAL_MINUTES=10
BETA_SERVER_PUBLIC_URL=https://dbm-beta.myftp.biz

# ── Salesforce ────────────────────────────────────────────────────────────────
SALESFORCE_BASE_URL=<preencher_localmente>
SALESFORCE_CLIENT_ID=<preencher_localmente>
SALESFORCE_CLIENT_SECRET=<preencher_localmente>
